{
  "name": "nodemem",
  "version": "0.1.0",
  "private": false,
  "description": "Provider-agnostic passive memory for agent systems — notices entities in activity streams, surfaces noteworthy suggestions, learns from dismissals, and deduplicates.",
  "type": "module",
  "license": "MIT",
  "author": "Homen Shum",
  "homepage": "https://github.com/HomenShum/NodeMem",
  "repository": {
    "type": "git",
    "url": "https://github.com/HomenShum/NodeMem.git"
  },
  "bin": {
    "nodemem": "./bin/nodemem.mjs"
  },
  "keywords": [
    "agent",
    "memory",
    "passive-intelligence",
    "entity-detection",
    "dedup",
    "dismissal-learning",
    "convex",
    "context-engineering"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit",
    "demo": "tsx demo/runNodeMemDemo.ts",
    "demo:node": "node demo/runNodeMemDemo.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "nodemem:smoke": "tsx scripts/nodemem-smoke.ts --json-out docs/eval/nodemem-smoke.json",
    "nodemem:in-memory:smoke": "tsx scripts/nodemem-in-memory-smoke.ts --json-out docs/eval/nodemem-in-memory-smoke.json",
    "nodemem:convex:smoke": "tsx scripts/nodemem-convex-smoke.ts --json-out docs/eval/nodemem-convex-smoke.json",
    "secret-scan": "node scripts/secret-scan.mjs",
    "prepush": "npm run secret-scan && npm run nodemem:smoke && npm run nodemem:in-memory:smoke && npm run typecheck && npm run test"
  },
  "dependencies": {
    "convex": "^1.41.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
